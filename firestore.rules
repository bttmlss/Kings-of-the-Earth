rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isUserAuthorized(uid) {
      return request.auth != null && uid == request.auth.uid;
    }

    function isValidCampaign(data) {
      return data.keys().hasAll(['id', 'domainTitle', 'creatorId', 'creatorName', 'createdAt', 'status'])
        && data.keys().hasOnly(['id', 'domainTitle', 'creatorId', 'creatorName', 'createdAt', 'status', 'domainType', 'currentKingId', 'currentTitleHistoryId'])
        && data.id is string && data.id.size() <= 100
        && data.domainTitle is string && data.domainTitle.size() <= 150
        && isUserAuthorized(data.creatorId)
        && data.creatorName is string && data.creatorName.size() <= 100
        && data.createdAt is timestamp
        && data.status in ['live', 'taken_down']
        && (!data.keys().hasAll(['domainType']) || (data.domainType is string && data.domainType.size() <= 60))
        && (!data.keys().hasAll(['currentKingId']) || (data.currentKingId is string || data.currentKingId == null))
        && (!data.keys().hasAll(['currentTitleHistoryId']) || (data.currentTitleHistoryId is string || data.currentTitleHistoryId == null));
    }

    match /campaigns_v2/{campaignId} {
      allow read: if true;
      allow create: if false;
      allow update: if (
        isUserAuthorized(existing().creatorId)
        && incoming().diff(existing()).affectedKeys().hasOnly(['status'])
        && incoming().status in ['live', 'taken_down']
      );
      allow delete: if false;
    }

    function isCampaignCreator(campaignId, uid) {
      return request.auth != null && get(/databases/$(database)/documents/campaigns_v2/$(campaignId)).data.creatorId == uid;
    }

    function isValidCandidate(data) {
      return data.keys().hasAll(['id', 'userId', 'displayName', 'voteCount', 'joinedAt'])
        && data.keys().size() >= 5 && data.keys().size() <= 7
        && data.id is string && data.id.size() <= 128
        && isUserAuthorized(data.userId)
        && data.displayName is string && data.displayName.size() <= 100
        && data.voteCount is int
        && data.joinedAt is timestamp
        && (!data.keys().hasAll(['photoURL']) || (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 1000)))
        && (!data.keys().hasAll(['bio']) || (data.bio == null || (data.bio is string && data.bio.size() <= 1000)));
    }

    match /user_profiles/{userId} {
      allow read: if true;
      allow write: if isUserAuthorized(userId);
      
      match /daily_engagement/{date} {
        allow read: if true;
        allow write: if true;
      }
    }

    match /campaigns_v2/{campaignId}/candidates/{candidateId} {
      allow read: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    function isValidVoteLog(data) {
      return data.keys().hasAll(['id', 'voterId', 'candidateId', 'votedAt'])
        && data.keys().size() >= 4 && data.keys().size() <= 7
        && data.id is string && data.id.size() <= 128
        && isUserAuthorized(data.voterId)
        && data.candidateId is string && data.candidateId.size() <= 128
        && data.votedAt is timestamp
        && (!data.keys().hasAll(['latitude']) || (data.latitude == null || data.latitude is number))
        && (!data.keys().hasAll(['longitude']) || (data.longitude == null || data.longitude is number))
        && (!data.keys().hasAll(['city']) || (data.city == null || data.city is string));
    }

    match /{path=**}/candidates/{candidateId} {
      allow read: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    match /{path=**}/votes/{voteId} {
      allow read: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    function isValidTitleHistory(data) {
      return data.keys().hasAll(['holderUserId', 'holderDisplayName', 'voteCountAtTransition', 'startedAt', 'endedAt', 'deletedByUser', 'deletedAt'])
        && data.keys().size() == 7
        && data.holderUserId is string
        && data.holderDisplayName is string
        && data.voteCountAtTransition is number && data.voteCountAtTransition > 0
        && data.startedAt == request.time
        && data.endedAt == null
        && data.deletedByUser == false
        && data.deletedAt == null;
    }

    function isValidTitleHistoryUpdate(incoming, existing) {
       return request.auth != null
         && incoming.diff(existing).affectedKeys().hasOnly(['endedAt'])
         && existing.endedAt == null
         && incoming.endedAt == request.time;
    }

    match /campaigns_v2/{campaignId}/titleHistory/{historyId} {
      allow read: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    match /campaigns_v2/{campaignId}/courts/{userId} {
      allow read: if true;
      allow write: if request.auth != null && userId == request.auth.uid;
    }

    match /campaigns_v2/{campaignId}/daily_candles/{dateStr} {
      allow read: if true;
      allow write: if false;
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likesCount', 'comments'])
      );
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /follows/{followId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.followerId == request.auth.uid;
      allow update: if request.auth != null && (request.resource.data.followerId == request.auth.uid || request.resource.data.followingId == request.auth.uid);
      allow delete: if request.auth != null;
    }

    match /reports/{reportId} {
      allow read: if request.auth != null && resource.data.reporterId == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /notifications/{notifId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
